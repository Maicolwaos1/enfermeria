# Plantilla de variables de entorno.
# Copia este archivo como ".env" y pon tus propios datos de MySQL.
# (El .env real NO se sube a GitHub.)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_contraseña_de_mysql
DB_NAME=clinica_db

PORT=3000

# Secreto para firmar los tokens JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_una_cadena_larga_y_secreta
